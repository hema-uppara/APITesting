{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Behave with Allure",
            "type": "python",
            "request": "launch",
            "module": "behave",
            "args": [
                "-f",
                "allure_behave.formatter:AllureFormatter",
                "-o",
                "allure-results"
            ],
            "console": "integratedTerminal"
        }
    ]
}